{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Voice Memory Assistant",
  "version": "0.1.0",
  "identifier": "com.codex.localvoiceassistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Local Voice Memory Assistant",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/backend-runtime", "resources/default-settings.json"]
  }
}
